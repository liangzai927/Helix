{
  "name": "helix-agent-vscode",
  "displayName": "Helix Agent",
  "version": "0.1.0",
  "private": true,
  "publisher": "liangzai927",
  "description": "VS Code client for Helix Agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/liangzai927/Helix.git"
  },
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:helix.hello",
    "onView:helix.chat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "helix.hello",
        "title": "Helix: Hello"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helix.sidebar",
          "title": "Helix",
          "icon": "media/helix.svg"
        }
      ]
    },
    "views": {
      "helix.sidebar": [
        {
          "id": "helix.chat",
          "name": "Helix",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:production": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "pnpm build:production",
    "vsix": "vsce package --no-dependencies --out dist/helix-agent-vscode.vsix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"shared/**/*.ts\" \"src/**/*.ts\" \"webview-ui/src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@helix-agent/core": "workspace:*",
    "@helix-agent/protocol": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
