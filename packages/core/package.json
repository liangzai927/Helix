{
  "name": "@helix-agent/core",
  "version": "0.1.0",
  "private": true,
  "description": "Core runtime workspace package for Helix Agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@helix-agent/models": "workspace:*",
    "@helix-agent/protocol": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "node --import tsx demo/run-runtime-demo.ts",
    "typecheck": "tsc -p tsconfig.demo.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"demo/**/*.ts\"",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsx": "^4.23.1"
  }
}
